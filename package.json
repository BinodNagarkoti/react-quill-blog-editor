{
  "name": "react-quill-blog-editor",
  "version": "0.1.0",
  "description": "A React wrapper around Quill 2 preconfigured for blog content: fonts, tables, colors, alignment, line spacing, and non-base64 image uploads.",
  "type": "module",
  "license": "MIT",
  "keywords": ["react", "quill", "rich-text-editor", "wysiwyg", "blog"],
  "files": ["dist", "bin", ".claude/skills/react-quill-blog-editor/SKILL.md"],
  "bin": {
    "react-quill-blog-editor": "./bin/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": ["*.css"],
  "scripts": {
    "dev": "vite --config example/vite.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:example": "vite build --config example/vite.config.ts",
    "preview": "vite preview --config example/vite.config.ts",
    "dev:docs": "vite --config docs/vite.config.ts",
    "build:docs": "vite build --config docs/vite.config.ts",
    "preview:docs": "vite preview --config docs/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p example/tsconfig.json --noEmit && tsc -p docs/tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "quill": "^2.0.3",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "katex": ">=0.16.0"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "katex": "^0.17.0",
    "multer": "^2.2.0",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1"
  }
}
